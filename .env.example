# Supabase (auth + tablas del agente)
SUPABASE_URL=https://tu-proyecto.supabase.co
SUPABASE_SERVICE_ROLE_KEY=tu-service-role-key

# Railway PostgreSQL (datos energéticos reales)
RAILWAY_DATABASE_URL=postgresql://usuario:password@host:puerto/railway

# Puerto del servidor del agente
PORT=3100

# Contexto privado EnergyOS Data Room (opcional)
ENABLE_PRIVATE_CONTEXT=false
ENERGYOS_DATA_ROOM_FUNCTION_URL=https://tu-proyecto.supabase.co/functions/v1/client-data-room/ai-context
ENERGYOS_PRIVATE_CONTEXT_TIMEOUT_MS=8000
REQUIRE_AGENT_AUTH=false

# Smoke test opcional: npm run smoke:ai-context
ENERGYOS_AGENT_URL=http://localhost:3100
ENERGYOS_SMOKE_USER_JWT=
ENERGYOS_SMOKE_NEMO=
ENERGYOS_SMOKE_COMPANY_ID=
ENERGYOS_SMOKE_PERIOD=2026-04

# ─── Proveedor IA (configurar AL MENOS UNO para modo agéntico) ───
# Si no se configura ninguno, el agente opera en modo determinístico (sin IA)

# Opción 1: Anthropic (Claude)
ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Opción 2: OpenAI (GPT)
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o

# Opcion 3: Google Gemini
# GEMINI_API_KEY=...
# GEMINI_MODEL=gemini-2.5-flash
